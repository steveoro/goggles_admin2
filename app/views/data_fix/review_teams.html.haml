-# frozen_string_literal: true

= render(partial: 'data_fix_legacy/modal_progress')

.container-fluid
  %h2 Data-Fix V2 • Step 2: Teams (Phase 2)
  .mb-2
    = render(partial: 'data_fix/step_tabs', locals: { active_step: 2, file_path: @file_path })

  -# Phase Navigation buttons
  .d-flex.justify-content-between.my-2
    = link_to('< Back to file list', pull_result_files_path, class: 'btn btn-outline-secondary mr-2')
    = link_to('Proceed to Step 3 (Swimmers)', review_swimmers_path(request.query_parameters.merge(phase3_v2: 1)),
              class: 'btn btn-primary')

  -# Phase Metadata card
  - basename = File.basename(@file_path).split('.json').first
  = render(partial: 'data_fix/phase_metadata', locals: { phase_number: 2, metadata: @phase2_meta,
                                                         extra_info: basename })
  -# Search and filter controls
  .card.my-2
    .card-header
      = form_tag(review_teams_path, method: :get, class: 'form-inline') do
        = hidden_field_tag :file_path, @file_path
        = hidden_field_tag :phase2_v2, 1
        .form-group.mr-2
          %label.mr-1{ for: 'q' } Filter
          = text_field_tag :q, @q, class: 'form-control form-control-sm', placeholder: 'Search teams...'
        .form-group.mr-2
          %label.mr-1{ for: 'teams_per_page' } Per page
          = select_tag :teams_per_page, options_for_select([50, 100, 150], @per_page), class: 'form-control form-control-sm'
        .form-group.mr-2
          .custom-control.custom-checkbox
            = check_box_tag :unmatched, '1', params[:unmatched].present?, class: 'custom-control-input', id: 'unmatched-filter'
            %label.custom-control-label{ for: 'unmatched-filter' } Show needing review
          %small.text-muted.ml-1 (unmatched + yellow/red matches)
        .form-group.mr-2
          .custom-control.custom-checkbox
            = check_box_tag :name_differs, '1', params[:name_differs].present?, class: 'custom-control-input', id: 'name-differs-filter'
            %label.custom-control-label{ for: 'name-differs-filter' } Name != Key
          %small.text-muted.ml-1 (edited name differs from import key)
        = submit_tag 'Apply', class: 'btn btn-sm btn-primary mr-1'
        = link_to 'Clear', review_teams_path(file_path: @file_path, phase2_v2: 1), class: 'btn btn-sm btn-light'
    .card-body.py-0
      -# Pagination controls (top) and Add button
      .d-flex.justify-content-between.align-items-center
        %div
          %strong Page:
          = @page
          = "/"
          = @total_pages
          &nbsp;•&nbsp;
          %strong Rows:
          = @row_range
          = "/"
          = @total_count
        .flex-grow-1.pt-3
          - if @items.present?
            = render(PageLinksForArrayComponent.new(data: @items, total_count: @total_count, page: @page,
                                                    per_page: @per_page, param_name: :teams_page))
        %div
          = form_tag(data_fix_add_team_path, method: :post, class: 'd-inline', onsubmit: "return confirm('Add a new blank team?');") do
            = hidden_field_tag :file_path, @file_path
            = hidden_field_tag :teams_page, params[:teams_page] if params[:teams_page].present?
            = hidden_field_tag :teams_per_page, params[:teams_per_page] if params[:teams_per_page].present?
            = hidden_field_tag :q, params[:q] if params[:q].present?
            = hidden_field_tag :unmatched, params[:unmatched] if params[:unmatched].present?
            = hidden_field_tag :name_differs, params[:name_differs] if params[:name_differs].present?
            %button.btn.btn-sm.btn-success{ type: 'submit' }
              %i.fa.fa-plus
              Add Team

  -# Collapsible card layout for each team
  - if @items.empty?
    .alert.alert-info
      %em No teams found. Adjust filters or rescan to rebuild phase2 file.
  - else
    - @items.each_with_index do |team_hash, idx|
      :ruby
        team_index = ((@page - 1) * @per_page) + idx
        team_key = team_hash['key'] || team_hash['name']
        team_name = team_hash['name'] || team_key
        editable_name = team_hash['editable_name'] || team_name
        team_id = team_hash['team_id']
        city_id = team_hash['city_id']
        name_variations = team_hash['name_variations']
        
        # Visual indicators
        has_match = team_id.to_i.positive?
        similar_affiliated = team_hash['similar_affiliated'] == true
        
        # Check for required data (for teams, only name is required)
        has_missing_data = team_name.blank?
        
        # Determine visual styling
        if has_match
          # Matched team
          card_bg = 'bg-light'
          border_color = 'border-secondary'
          icon_class = 'fa-check-circle text-success'
          icon_title = 'Matched'
        elsif has_missing_data
          # Missing required data (extremely rare for teams since name is always present)
          card_bg = 'bg-light-red'
          border_color = 'border-danger'
          icon_class = 'fa-exclamation-triangle text-danger'
          icon_title = 'Missing required data'
        elsif similar_affiliated
          # New team but a similar team is already affiliated this season
          card_bg = 'bg-light-yellow'
          border_color = 'border-warning'
          icon_class = 'fa-exclamation-triangle text-warning'
          icon_title = 'Similar team in season'
        else
          # New team with all required data
          card_bg = 'bg-light-yellow'
          border_color = 'border-warning'
          icon_class = 'fa-plus-circle text-warning'
          icon_title = 'New/Unmatched'
        end
        border_width = 'border-2'

      = render(partial: 'team_form_card',
               locals: { file_path: @file_path, api_url: @api_url, team_hash:, team_index:,
                         team_key:, team_name:, editable_name:, team_id:, city_id:,
                         name_variations:, has_match:, has_missing_data:, similar_affiliated:,
                         card_bg:, border_color:, border_width:, icon_class:, icon_title: })

  -# Pagination controls (bottom)
  .mt-3
    - if @items.present?
      = render(PageLinksForArrayComponent.new(data: @items, total_count: @total_count, page: @page,
                                              per_page: @per_page, param_name: :teams_page))
  .mb-4 &nbsp;

:javascript
  $(document).on('click', '.verify-team-btn', function(e) {
    e.preventDefault();
    var btn = $(this);
    var filePath = btn.data('file_path');
    var teamKey = btn.data('team_key');
    var candidateTeamId = btn.data('candidate_team_id');
    var targetSelector = btn.data('target');
    var panel = $(targetSelector);
    panel.collapse('show');

    $.ajax({
      url: '/data_fix/verify_team',
      method: 'GET',
      data: { file_path: filePath, team_key: teamKey, candidate_team_id: candidateTeamId },
      dataType: 'json',
      success: function(data) {
        panel.find('> div').html(renderTeamVerifyPanel(data));
      },
      error: function(xhr) {
        var msg = xhr.responseJSON ? xhr.responseJSON.error : 'Verification failed';
        panel.find('> div').html('<div class="text-danger"><i class="fa fa-exclamation-triangle"></i> ' + msg + '</div>');
      }
    });
  });

  function renderTeamVerifyPanel(data) {
    var html = '';
    var confClass = { high: 'text-success', medium: 'text-warning', low: 'text-danger', none: 'text-muted' };
    var confLabel = { high: 'HIGH', medium: 'MEDIUM', low: 'LOW', none: 'N/A' };
    var cls = confClass[data.confidence] || 'text-muted';
    var lbl = confLabel[data.confidence] || 'N/A';

    html += '<div class="mb-2"><strong>Confidence: <span class="' + cls + '">' + lbl + '</span></strong>';
    html += ' (' + data.confirmed + '/' + data.total + ' swimmers confirmed)</div>';

    if (data.swimmers && data.swimmers.length > 0) {
      html += '<table class="table table-sm table-bordered mb-0"><thead><tr><th>Swimmer</th><th>ID</th><th>Badge Teams</th><th>Match</th></tr></thead><tbody>';
      data.swimmers.forEach(function(s) {
        var matchIcon = s.matches_candidate
          ? '<span class="text-success"><i class="fa fa-check-circle"></i> Yes</span>'
          : '<span class="text-danger"><i class="fa fa-times-circle"></i> No</span>';
        var teams = (s.badge_teams || []).map(function(bt) { return bt.team_name + ' (ID: ' + bt.team_id + ')'; }).join(', ') || '<em>No badges</em>';
        html += '<tr><td>' + s.name + '</td><td>' + s.swimmer_id + '</td><td>' + teams + '</td><td>' + matchIcon + '</td></tr>';
      });
      html += '</tbody></table>';
    } else {
      html += '<div class="text-muted"><em>No matched swimmers found for this team in Phase 3.</em></div>';
    }
    return html;
  }